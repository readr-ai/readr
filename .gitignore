# Xcode
*.xcodeproj/*
!*.xcodeproj/project.pbxproj
*.xcworkspace/xcuserdata/
xcuserdata/
DerivedData/
build/
*.xcuserstate

# Generated by XcodeGen (project is regenerated from project.yml)
Readr.xcodeproj/
App/Info.plist

# Swift Package Manager
.build/
.swiftpm/
# Root Package.resolved is ignored on purpose. The root Package.swift (ReadrKit)
# declares zero dependencies, so any root Package.resolved is empty or — after a
# Linux verification run — polluted with unrelated swift-crypto/swift-asn1 patch
# artifacts that must never ship. ZIPFoundation (declared in project.yml, the
# Xcode app target) is pinned deterministically via `exactVersion: "0.9.19"`, and
# the Xcode project/workspace itself is generated by XcodeGen and git-ignored
# above, so there is no committable resolved file to track here.
/Package.resolved

# macOS
.DS_Store

# Secrets / local config
*.env
secrets.plist

# Misc
*.log
